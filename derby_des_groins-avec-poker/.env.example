# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=derby_secret

# ── Flask ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-in-production
FLASK_ENV=production
FLASK_DEBUG=false

# ── Derby des Groins ──────────────────────────────────────────────────
DERBY_TIMEZONE=Europe/Paris
# DERBY_DISABLE_SCHEDULER=0
# DERBY_FORCE_SCHEDULER=1   (set automatiquement dans docker-compose)

# ── Sessions ──────────────────────────────────────────────────────────
# Sessions stockees cote serveur en base (Flask-Session + SQLAlchemy).
# Table : flask_sessions, TTL : 30 jours, prefixe : derby:
# Aucune config supplementaire requise — utilise la meme base que l'app.

# ── Serveur ───────────────────────────────────────────────────────────
PORT=5001
