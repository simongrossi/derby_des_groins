+        seenToasts = JSON.parse(localStorage.getItem(toastStorageKey) || '{}') || {};
+    } catch (e) {
+        seenToasts = {};
+    }
+
+    function persistSeenToasts() {
+        var keys = Object.keys(seenToasts);
+        if (keys.length > 100) {
+            keys.sort(function(a, b) { return (seenToasts[b] || 0) - (seenToasts[a] || 0); });
+            for (var i = 100; i < keys.length; i++) delete seenToasts[keys[i]];
+        }
+        localStorage.setItem(toastStorageKey, JSON.stringify(seenToasts));
+    }
+
+    function showToast(eventItem) {
+        if (!toastContainer || !eventItem || !eventItem.id) return;
+        if (seenToasts[eventItem.id]) return;
+        seenToasts[eventItem.id] = Date.now();
+        persistSeenToasts();
+
+        var tone = eventItem.category || 'info';
+        var colors = {
+            error: 'border-red-400/35 bg-red-500/15 text-red-100',
+            warning: 'border-amber-400/35 bg-amber-500/15 text-amber-100',
